# Pace Configuration Reference

# Database
DATABASE_URL=postgresql+asyncpg://pace:pace@db:5432/pace
SYNC_DATABASE_URL=postgresql://pace:pace@db:5432/pace
TIMESCALE_ENABLED=false

# Security & Secrets (CHANGE FOR PRODUCTION!)
SECRET_KEY=pace-development-secret-key-change-in-production-32bytes
INGESTION_KEY_SALT=pace-ingestion-salt-32bytes-secret

# Frontend & CORS
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:8000"]
NEXT_PUBLIC_API_URL=http://localhost:8000/v1

# Demo & Seeding Options
DEMO_MODE=true
SEEDED_USER_EMAIL=demo@pace.dev
SEEDED_USER_PASSWORD=PaceDemo123!

# Operations
DATA_RETENTION_DAYS=90
WORKER_ENABLED=true
